SANDFEST_ENV=development
SANDFEST_API_PORT=8788
SANDFEST_API_PUBLIC_BASE_URL=https://api.heyelab.com/sandfest
SANDFEST_ADMIN_BASE_URL=https://sandfest-admin.heyelab.com
SANDFEST_ADMIN_API_TOKEN=replace-with-long-random-token
SANDFEST_ADMIN_ROLE=super_admin
SANDFEST_ADMIN_ACTOR_ID=local-admin

# Admin auth mode. Defaults to 'bearer-token' (the SANDFEST_ADMIN_* env vars
# above) for local dev. Production deployments use Heyelab's identity provider —
# see docs/heyelab-auth-contract.md for the JWKS/claim/role contract Heyelab
# must publish at auth.heyelab.com. The defaults below are pre-filled for the
# eventual Heyelab IdP deployment.
SANDFEST_AUTH_MODE=bearer-token
SANDFEST_AUTH_JWKS_URL=https://auth.heyelab.com/.well-known/jwks.json
SANDFEST_AUTH_ISSUER=https://auth.heyelab.com/
SANDFEST_AUTH_AUDIENCE=https://api.heyelab.com/sandfest
SANDFEST_AUTH_ROLE_CLAIM=sandfest_role
SANDFEST_AUTH_ACTOR_CLAIM=sub
# Fallback: comma-separated user_id:role pairs, used in JWT mode when the
# token has no sandfest_role claim. Lets you ship before the IdP is wired
# to emit roles — keys are sub-claim values, roles are one of the six.
# SANDFEST_AUTH_USER_ROLES=user_abc:super_admin,user_xyz:ops_admin

# --- Clerk dev instance (Heyelab "Texas Sandfest" app, Hobby tier) ---
# To use this for staging instead of the Heyelab IdP defaults above, swap:
#   SANDFEST_AUTH_JWKS_URL=https://distinct-opossum-3.clerk.accounts.dev/.well-known/jwks.json
#   SANDFEST_AUTH_ISSUER=https://distinct-opossum-3.clerk.accounts.dev
#   SANDFEST_AUTH_AUDIENCE=             # leave blank — Clerk session tokens have no aud
#   SANDFEST_AUTH_ROLE_CLAIM=public_metadata.sandfest_role
# When the Clerk dashboard accepts a session-token customization with the
# sandfest_role claim, the role-claim path can be set to sandfest_role
# (top-level) instead of the nested public_metadata path.
SANDFEST_CORS_ORIGINS=http://127.0.0.1:4173,http://127.0.0.1:5173,https://www.texassandfest.org,https://texassandfest.org,https://sandfest-admin.heyelab.com
SANDFEST_RATE_LIMIT_WINDOW_MS=60000
SANDFEST_PUBLIC_RATE_LIMIT=600
SANDFEST_ADMIN_RATE_LIMIT=120
SANDFEST_CHECKOUT_RATE_LIMIT=30

# Postgres (optional). When SANDFEST_DATABASE_URL is set, the admin API
# stores orders, payment events, fulfillment, audit, snapshots, and
# mutable config in Postgres instead of local JSON files. Schema is
# applied automatically on boot from lib/db/schema.sql, and existing
# config docs under data/config + data/processed are seeded on first run.
SANDFEST_DATABASE_URL=
# SANDFEST_DATABASE_SSL=no-verify   # 'false' to disable TLS, 'no-verify' for self-signed, otherwise verified TLS
# SANDFEST_DATABASE_POOL_MAX=10

QB_ENVIRONMENT=sandbox
QB_CLIENT_ID=
QB_CLIENT_SECRET=
QB_REDIRECT_URI=http://127.0.0.1:8787/api/integrations/quickbooks/callback
QB_REALM_ID=
QB_REFRESH_TOKEN=
QB_MINOR_VERSION=75
QB_OAUTH_STATE=replace-with-random-state
QB_WRITE_TOKEN_FILE=false

STRIPE_TICKETING_ENABLED=false
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_SUCCESS_URL=http://127.0.0.1:5173/tickets/success?session_id={CHECKOUT_SESSION_ID}
STRIPE_CANCEL_URL=http://127.0.0.1:5173/#tickets
STRIPE_APPLE_PAY_DOMAIN=texassandfest.org
STRIPE_APPLE_PAY_MERCHANT_ID=merchant.org.texassandfest

# --- SMS (Twilio) — proposed. Ticket confirmations, event reminders, public
# alerts. Requires A2P 10DLC brand/campaign registration + opt-in/consent
# capture before sending. See docs/incoming-access-intake.md. ---
SMS_ENABLED=false
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
TWILIO_MESSAGING_SERVICE_SID=

# --- Maps (Mapbox) — proposed. Sculptor/POI interactive map on web + iOS.
# MapLibre + self-hosted tiles is the open-source alternative (no token). ---
MAPBOX_ACCESS_TOKEN=
