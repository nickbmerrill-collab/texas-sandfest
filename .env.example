SANDFEST_ENV=development
# Explicit annual operations namespace. Change only through the archive-first
# event rollover workflow; it must match the published event guide id.
SANDFEST_EVENT_ID=texas-sandfest-2027
# Production reconciles failed launch gates into assigned work-board tasks at
# startup and every 15 minutes by default. Set a bounded millisecond interval
# to override it; /ready also fails until reconciliation succeeds and whenever
# a later automatic run fails. Setting 0 disables automation and fails production readiness.
# SANDFEST_DEPLOYMENT_TASK_SYNC_INTERVAL_MS=900000
# Optional isolated file data plane for staging or board demonstrations.
# SANDFEST_RUNTIME_ROOT=.sandfest-runtime/board-2027
SANDFEST_API_PORT=8788
SANDFEST_API_PUBLIC_BASE_URL=https://sandfest-api.heyelab.com
SANDFEST_ADMIN_BASE_URL=https://sandfest-admin.heyelab.com
SANDFEST_ADMIN_API_TOKEN=replace-with-long-random-token
SANDFEST_ADMIN_ROLE=super_admin
SANDFEST_ADMIN_ACTOR_ID=local-admin
# The Visitor / Operations switch is local-development-only by default. Set
# this only for a private, explicit presentation build; public builds must omit it.
VITE_SANDFEST_OPS_DEMO=false
# Public Cloudflare Turnstile site key for vendor/sponsor forms. Production
# visitor builds fail if this is missing or is one of Cloudflare's test keys.
# VITE_SANDFEST_TURNSTILE_SITE_KEY=

# Admin auth mode. Defaults to 'bearer-token' (the SANDFEST_ADMIN_* env vars
# above) for local dev. Production deployments use Heyelab's identity provider —
# see docs/heyelab-auth-contract.md for the JWKS/claim/role contract Heyelab
# must publish at auth.heyelab.com. The defaults below are pre-filled for the
# eventual Heyelab IdP deployment.
SANDFEST_AUTH_MODE=bearer-token
SANDFEST_AUTH_JWKS_URL=https://auth.heyelab.com/.well-known/jwks.json
SANDFEST_AUTH_ISSUER=https://auth.heyelab.com/
SANDFEST_AUTH_AUDIENCE=https://sandfest-api.heyelab.com
SANDFEST_AUTH_ROLE_CLAIM=sandfest_role
SANDFEST_AUTH_ACTOR_CLAIM=sub
# Static admin build settings. Leave VITE_SANDFEST_AUTH_MODE unset locally to
# retain the manual development-token field. Production sets these in Render.
# VITE_SANDFEST_AUTH_MODE=oidc
# VITE_SANDFEST_AUTH_ISSUER=https://auth.heyelab.com/
# VITE_SANDFEST_AUTH_CLIENT_ID=registered-public-spa-client-id
# VITE_SANDFEST_AUTH_REDIRECT_URI=https://sandfest-admin.heyelab.com/
# VITE_SANDFEST_AUTH_POST_LOGOUT_REDIRECT_URI=https://sandfest-admin.heyelab.com/
# VITE_SANDFEST_AUTH_SCOPES=openid profile email
# VITE_SANDFEST_AUTH_AUDIENCE=https://sandfest-api.heyelab.com
# VITE_SANDFEST_API_BASE_URL=https://sandfest-api.heyelab.com
# Fallback: comma-separated user_id:role pairs, used in JWT mode when the
# token has no sandfest_role claim. Lets you ship before the IdP is wired
# to emit roles — keys are sub-claim values, roles are one of the six.
# SANDFEST_AUTH_USER_ROLES=user_abc:super_admin,user_xyz:ops_admin

# --- Clerk dev instance (Heyelab "Texas Sandfest" app, Hobby tier) ---
# To use this for staging instead of the Heyelab IdP defaults above, swap:
#   SANDFEST_AUTH_JWKS_URL=https://distinct-opossum-3.clerk.accounts.dev/.well-known/jwks.json
#   SANDFEST_AUTH_ISSUER=https://distinct-opossum-3.clerk.accounts.dev
#   SANDFEST_AUTH_AUDIENCE=             # leave blank — Clerk session tokens have no aud
#   SANDFEST_AUTH_ROLE_CLAIM=public_metadata.sandfest_role
# When the Clerk dashboard accepts a session-token customization with the
# sandfest_role claim, the role-claim path can be set to sandfest_role
# (top-level) instead of the nested public_metadata path.
SANDFEST_CORS_ORIGINS=http://127.0.0.1:4173,http://127.0.0.1:5173,https://sandfest.heyelab.com,https://www.texassandfest.org,https://texassandfest.org,https://sandfest-admin.heyelab.com
SANDFEST_RATE_LIMIT_WINDOW_MS=60000
SANDFEST_PUBLIC_RATE_LIMIT=1200
SANDFEST_PUBLIC_WRITE_RATE_LIMIT=60
SANDFEST_ADMIN_RATE_LIMIT=120
SANDFEST_CHECKOUT_RATE_LIMIT=30
SANDFEST_PARTNER_STATUS_RATE_LIMIT=30
SANDFEST_MAX_BODY_BYTES=262144
# Published public event facts must cite an official source rechecked within
# this window. Production readiness fails closed when the guide is stale.
SANDFEST_EVENT_GUIDE_SOURCE_MAX_AGE_DAYS=90
# Vendor/sponsor intake bot verification. Production always enforces this even
# if SANDFEST_TURNSTILE_ENABLED is omitted. Keep the secret server-side only.
SANDFEST_TURNSTILE_ENABLED=false
SANDFEST_TURNSTILE_SECRET_KEY=
SANDFEST_TURNSTILE_HOSTNAMES=www.texassandfest.org,texassandfest.org,sandfest.heyelab.com,nickbmerrill-collab.github.io
SANDFEST_TURNSTILE_TIMEOUT_MS=8000
# HMAC capability links for vendor/sponsor self-service status. The same
# 32+ character secret must be configured on the API and background worker.
SANDFEST_PARTNER_PORTAL_SECRET=
# Optional separate HMAC root for staff and volunteer task-update links. When
# empty, the partner portal secret is reused with a domain-separated signature.
SANDFEST_TASK_PORTAL_SECRET=
# Optional separate HMAC root for sponsor outreach preference links. When empty,
# the partner portal secret is reused with a domain-separated signature.
SANDFEST_OUTREACH_PREFERENCES_SECRET=
# Optional separate HMAC root for staff-issued sponsor application invitations.
# When empty, the partner portal secret is reused with domain separation. Keep
# the same value on the API and worker so campaign drafts carry valid links.
SANDFEST_SPONSOR_INVITATION_SECRET=
# Staff-triggered regional business discovery. The fixture provider is limited
# to development/board demos and is rejected in production.
OUTREACH_DISCOVERY_ENABLED=false
OUTREACH_DISCOVERY_PROVIDER=openstreetmap
# Optional 32+ character signing root; falls back to the partner portal secret.
OUTREACH_DISCOVERY_SECRET=
# OpenStreetMap public services require an identifying client and operator.
OUTREACH_DISCOVERY_USER_AGENT=TexasSandFest-PartnerOps/1.0
OUTREACH_DISCOVERY_CONTACT=operations@example.org
OUTREACH_DISCOVERY_NOMINATIM_URL=https://nominatim.openstreetmap.org/search
# Up to three reviewed HTTPS endpoints, tried in order only for transient errors.
# OUTREACH_DISCOVERY_OVERPASS_URL remains supported as a single-endpoint fallback.
OUTREACH_DISCOVERY_OVERPASS_URLS=https://overpass-api.de/api/interpreter,https://z.overpass-api.de/api/interpreter,https://overpass.private.coffee/api/interpreter
OUTREACH_DISCOVERY_TIMEOUT_MS=10000
SANDFEST_PUBLIC_SITE_URL=https://sandfest.heyelab.com
# Private sponsor creative and vendor compliance uploads. Production must use a persistent,
# non-public mount; metadata remains in the partner operations Postgres record.
SANDFEST_PARTNER_ASSET_DIR=
SANDFEST_PARTNER_ASSET_MAX_BYTES=10485760
# Staff-only board packets, exports, policies, and operational source files.
# Production must use a private persistent mount; never place this under public/.
SANDFEST_INCOMING_DOCUMENT_DIR=
SANDFEST_INCOMING_DOCUMENT_MAX_BYTES=20971520
# API/worker shared bearer secret for checksum-bound private source reads.
SANDFEST_DOCUMENT_EXTRACTION_SECRET=
# Worker-only API base; production requires HTTPS. Leave blank for local shared-disk mode.
SANDFEST_DOCUMENT_EXTRACTION_SOURCE_URL=
SANDFEST_DOCUMENT_EXTRACTION_TIMEOUT_MS=20000
# SANDFEST_API_HOST=0.0.0.0
# SANDFEST_DATABASE_POOL_MAX=40
# Shared rate limits across pods (optional — falls back to in-memory)
# Production requires one reachable shared limiter; local development may use memory.
# REDIS_URL=redis://127.0.0.1:6379
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
# Enforce ticket QR/order on People's Choice votes
SANDFEST_REQUIRE_TICKET_VOTE=false
# Background jobs use fenced leases. API and worker must share this duration;
# expired claims are recovered and a late worker cannot complete a newer claim.
SANDFEST_JOB_LEASE_MS=300000
# Production defaults to requiring every integration below before /ready can
# return 200. Use "none" only for an intentionally partial staging environment.
SANDFEST_REQUIRED_CAPABILITIES=stripe_ticketing,stripe_partner_payments,transactional_email,quickbooks_invoices,camera_ingest,staff_directory,outreach_discovery,sms_safety
# Live deployment acceptance defaults to the canonical hostnames. Override a
# target only for an intentional staging verification.
SANDFEST_LIVE_PUBLIC_URL=https://sandfest.heyelab.com/
SANDFEST_LIVE_API_URL=https://sandfest-api.heyelab.com/
SANDFEST_LIVE_ADMIN_URL=https://sandfest-admin.heyelab.com/
SANDFEST_LIVE_EXPECTED_EVENT_ID=texas-sandfest-2027
SANDFEST_DEPLOY_VERIFY_TIMEOUT_MS=12000
# Optional human-readable worker identity. Hostname + PID is used by default.
# SANDFEST_WORKER_ID=sandfest-worker-1

# Signed, metrics-only observations from local camera inference workers. Stream
# credentials and footage remain on local camera hosts and are never posted.
CAMERA_INGEST_ENABLED=false
# Production: JSON object keyed by credential ID. Bind every active key to one
# camera ID; keep old + new IDs active together during a rotation window.
# CAMERA_INGEST_KEYS={"north-gate-v1":{"cameraId":"north-gate","secret":"replace-with-32-or-more-characters"}}
CAMERA_INGEST_KEYS=
# Production defaults to the platform's eight known camera IDs. Set explicitly
# only when the approved source fleet changes.
CAMERA_INGEST_REQUIRED_CAMERA_IDS=ferry-loading,ferry-stacking,harbor-island-entrance,harbor-island-stacking,north-gate,south-gate,food-court,competition-corridor
# Development-only fallback when CAMERA_INGEST_KEYS is unset. Production
# intentionally rejects this shared credential mode.
CAMERA_INGEST_SECRET=
CAMERA_INGEST_MAX_SKEW_SECONDS=300
CAMERA_INGEST_RATE_LIMIT=600
# Production camera readiness also requires a reviewed detector decision bound
# to the exact model bytes deployed on every edge host. These values are an
# operator attestation, not a substitute for legal review or field calibration.
CAMERA_MODEL_APPROVAL_STATUS=pending
CAMERA_MODEL_NAME=
CAMERA_MODEL_VERSION=
CAMERA_MODEL_SHA256=
CAMERA_MODEL_LICENSE_REFERENCE=
CAMERA_MODEL_APPROVED_BY=
CAMERA_MODEL_APPROVED_AT=
CAMERA_MODEL_DECISION_REFERENCE=

# Postgres (optional). When SANDFEST_DATABASE_URL is set, the admin API
# stores orders, payment events, fulfillment, audit, snapshots, and
# mutable config in Postgres instead of local JSON files. Schema is
# applied automatically on boot from lib/db/schema.sql, and existing
# config docs under data/config + data/processed are seeded on first run.
SANDFEST_DATABASE_URL=
# Production recovery is a launch gate. The current Render profile supplies a
# paid managed Postgres recovery window plus daily private-asset snapshots.
# Record drill timestamps only after restoring both into isolated targets and
# verifying them; repeat at least every 90 days.
SANDFEST_BACKUP_PROVIDER=
SANDFEST_DATABASE_RECOVERY_WINDOW_DAYS=0
SANDFEST_ASSET_SNAPSHOT_RETENTION_DAYS=0
SANDFEST_DATABASE_RESTORE_DRILL_AT=
SANDFEST_ASSET_RESTORE_DRILL_AT=
SANDFEST_RESTORE_DRILL_MAX_AGE_DAYS=90
# Read-only verification target for `npm run recovery:verify`. Never point this
# or the asset verifier at the active SANDFEST_DATABASE_URL.
SANDFEST_RECOVERY_DATABASE_URL=
# SANDFEST_RECOVERY_DATABASE_SSL=no-verify
# Isolated snapshot mount for `npm run recovery:verify:assets`. The command
# refuses SANDFEST_PARTNER_ASSET_DIR and verifies every sponsor, vendor, and
# incoming-document upload referenced by the restored database.
SANDFEST_RECOVERY_ASSET_DIR=
SANDFEST_RECOVERY_ASSET_MIN_FILES=1
# File-mode isolation/persistent-mount overrides. Postgres remains required for production.
# SANDFEST_ORDER_DIR=
# SANDFEST_PAYMENT_EVENT_DIR=
# SANDFEST_FULFILLMENT_DIR=
# SANDFEST_DATABASE_SSL=no-verify   # 'false' to disable TLS, 'no-verify' for self-signed, otherwise verified TLS
# SANDFEST_DATABASE_POOL_MAX=10

QB_ENVIRONMENT=sandbox
QB_INVOICE_SYNC_ENABLED=false
QB_CLIENT_ID=
QB_CLIENT_SECRET=
QB_REDIRECT_URI=http://127.0.0.1:8787/api/integrations/quickbooks/callback
# At least 32 random characters. Production Render creates this once and shares
# it with the API and worker; changing it invalidates stored OAuth credentials.
QB_TOKEN_ENCRYPTION_KEY=
# Optional migration fallback. Admin OAuth stores realm/token encrypted instead.
QB_REALM_ID=
QB_REFRESH_TOKEN=
QB_MINOR_VERSION=75
QB_OAUTH_STATE=replace-with-random-state
QB_WRITE_TOKEN_FILE=false
# QuickBooks Item IDs can be set per sponsor tier in the admin editor. These
# serve as fallbacks for sponsor tiers and vendor fee invoices.
QB_SPONSOR_ITEM_ID=
QB_VENDOR_ITEM_ID=

STRIPE_TICKETING_ENABLED=false
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_WEBHOOK_TOLERANCE_SECONDS=300
STRIPE_SUCCESS_URL=http://127.0.0.1:5173/tickets/success?session_id={CHECKOUT_SESSION_ID}
STRIPE_CANCEL_URL=http://127.0.0.1:5173/#tickets
# Review-gated vendor/sponsor invoice checkout. Uses the same Stripe account and
# webhook secret, but trusted one-off amounts come from approved server invoices.
STRIPE_PARTNER_PAYMENTS_ENABLED=false
STRIPE_PARTNER_SUCCESS_URL=http://127.0.0.1:5173/#partner-payment-success?session_id={CHECKOUT_SESSION_ID}
STRIPE_PARTNER_CANCEL_URL=http://127.0.0.1:5173/#partner-status
# Development/test override only. Production readiness requires https://api.stripe.com.
# STRIPE_API_BASE_URL=http://127.0.0.1:9999
STRIPE_APPLE_PAY_DOMAIN=texassandfest.org
STRIPE_APPLE_PAY_MERCHANT_ID=merchant.org.texassandfest

# --- Transactional partner email (Brevo) ---
# Public applications generate drafts only. Staff must approve each draft, and
# the worker sends only when this gate and all sender credentials are present.
TRANSACTIONAL_EMAIL_ENABLED=false
BREVO_API_KEY=
BREVO_SENDER_EMAIL=
BREVO_SENDER_NAME=Texas SandFest
BREVO_REPLY_TO_EMAIL=info@texassandfest.org
# Configure this same 32+ character bearer token in the Brevo transactional
# webhook. The API stores delivery, bounce, complaint, and unsubscribe outcomes.
BREVO_WEBHOOK_TOKEN=
# Development/test mock only. Production rejects every non-Brevo endpoint.
# BREVO_API_ENDPOINT=http://127.0.0.1:9998/v3/smtp/email

# --- Safety SMS (Twilio) ---
# Operator-confirmed public alerts only. The worker revalidates smsSafety consent
# immediately before send; signed callbacks track delivery and STOP/START/HELP.
# Keep marketing and safety on separately configured Messaging Services/numbers.
# Leave disabled until sender approval and docs/sms-safety.md acceptance pass.
SMS_ENABLED=false
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
TWILIO_MESSAGING_SERVICE_SID=
# Production must remain https://api.twilio.com. Override only for local tests.
TWILIO_API_BASE_URL=https://api.twilio.com
TWILIO_STATUS_CALLBACK_URL=https://sandfest-api.heyelab.com/api/webhooks/twilio/status
TWILIO_SAFETY_INBOUND_WEBHOOK_URL=https://sandfest-api.heyelab.com/api/webhooks/twilio/inbound/smsSafety
TWILIO_MARKETING_INBOUND_WEBHOOK_URL=https://sandfest-api.heyelab.com/api/webhooks/twilio/inbound/smsMarketing
SANDFEST_SMS_MAX_RECIPIENTS=500
SANDFEST_SMS_WEBHOOK_RATE_LIMIT=1200

# Loopback-only board demonstration provider. Never enable in production.
SANDFEST_BOARD_SMS_SANDBOX=false
SANDFEST_BOARD_SMS_PORT=8808
SANDFEST_BOARD_SMS_DELIVERY_DELAY_MS=750
BOARD_TWILIO_ACCOUNT_SID=
BOARD_TWILIO_AUTH_TOKEN=
BOARD_TWILIO_FROM_NUMBER=
SANDFEST_BOARD_SMS_INBOUND_WEBHOOK_URL=http://127.0.0.1:8806/api/webhooks/twilio/inbound/smsSafety

# --- Maps (Mapbox) — proposed. Sculptor/POI interactive map on web + iOS.
# MapLibre + self-hosted tiles is the open-source alternative (no token). ---
MAPBOX_ACCESS_TOKEN=
